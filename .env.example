/**
 * 环境变量示例文件
 * 复制为 .env 或 .env.local 并根据需要修改
 *
 * VITE_DATA_SOURCE 取值:
 *   mock  — 使用本地 Mock 数据（开发阶段）
 *   api   — 连接真实后端 API
 *   mixed — 混合模式
 */

# 应用标题
VITE_APP_TITLE=巅峰数据大屏

# 数据源: mock | api | mixed
VITE_DATA_SOURCE=mock

# API 基础地址（dataSource=api 时生效）
VITE_API_BASE_URL=/api

# 日志级别: debug | info | warn | error
VITE_LOG_LEVEL=debug

# 是否启用实时刷新
VITE_REALTIME=false
